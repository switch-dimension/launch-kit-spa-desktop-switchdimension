{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Launch Kit SPA Desktop SwitchDimension",
  "version": "0.1.0",
  "identifier": "com.switchdimension.launch-kit-spa-desktop",
  "build": {
    "frontendDist": "../apps/web/dist",
    "devUrl": "http://localhost:5167",
    "beforeDevCommand": "npm run dev --workspace=@launch-kit-spa-desktop-switchdimension/web",
    "beforeBuildCommand": "npm run build --workspace=@launch-kit-spa-desktop-switchdimension/web"
  },
  "app": {
    "windows": [
      {
        "title": "Launch Kit SPA Desktop SwitchDimension",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
